<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="protocol_hot_miles_prep" model="drift.protocol">
        <field name="name">Hot Miles Prep</field>
        <field name="slug">hot-miles-prep</field>
        <field name="sequence">10</field>
        <field name="pillar">Run</field>
        <field name="duration_minutes">8</field>
        <field name="intensity">Low</field>
        <field name="summary">A short pre-run protocol for heat, focus, and nasal control.</field>
        <field name="equipment">Heat cap optional</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_hot_miles_prep_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">10</field>
        <field name="name">Sip water before kit-up.</field>
        <field name="duration_seconds">60</field>
    </record>
    <record id="protocol_hot_miles_prep_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">20</field>
        <field name="name">Nasal-only warmup for four minutes.</field>
        <field name="duration_seconds">240</field>
    </record>
    <record id="protocol_hot_miles_prep_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">30</field>
        <field name="name">Run the first ten minutes under control.</field>
        <field name="duration_seconds">300</field>
    </record>

