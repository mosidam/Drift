<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="protocol_hot_miles_prep" model="drift.protocol">
        <field name="name">Hot Miles Prep</field>
        <field name="slug">hot-miles-prep</field>
        <field name="sequence">10</field>
        <field name="pillar">Run</field>
        <field name="duration_minutes">8</field>
        <field name="intensity">Low</field>
        <field name="summary">A short pre-run protocol for heat, focus, and nasal control.</field>
        <field name="equipment">Heat cap optional</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_hot_miles_prep_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">10</field>
        <field name="name">Sip water before kit-up.</field>
        <field name="duration_seconds">60</field>
    </record>
    <record id="protocol_hot_miles_prep_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">20</field>
        <field name="name">Nasal-only warmup for four minutes.</field>
        <field name="duration_seconds">240</field>
    </record>
    <record id="protocol_hot_miles_prep_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="sequence">30</field>
        <field name="name">Run the first ten minutes under control.</field>
        <field name="duration_seconds">300</field>
    </record>

    <record id="protocol_nasal_reset" model="drift.protocol">
        <field name="name">Nasal Reset</field>
        <field name="slug">nasal-reset</field>
        <field name="sequence">20</field>
        <field name="pillar">Breathe</field>
        <field name="duration_minutes">6</field>
        <field name="intensity">Calm</field>
        <field name="summary">A simple downshift protocol for airflow awareness after work or before sleep.</field>
        <field name="equipment">Nose strips optional</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_nasal_reset_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="sequence">10</field>
        <field name="name">Sit tall and soften the shoulders.</field>
        <field name="duration_seconds">60</field>
    </record>
    <record id="protocol_nasal_reset_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="sequence">20</field>
        <field name="name">Inhale through the nose for four.</field>
        <field name="duration_seconds">180</field>
    </record>
    <record id="protocol_nasal_reset_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="sequence">30</field>
        <field name="name">Exhale through the nose for six.</field>
        <field name="duration_seconds">120</field>
    </record>

    <record id="protocol_post_run_stretch" model="drift.protocol">
        <field name="name">Post-Run Stretch</field>
        <field name="slug">post-run-stretch</field>
        <field name="sequence">25</field>
        <field name="pillar">Rest</field>
        <field name="duration_minutes">10</field>
        <field name="intensity">Mobility</field>
        <field name="summary">A simple guided stretch for calves, hips, hamstrings, and low back after logged volume.</field>
        <field name="equipment">Mat optional</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_post_run_stretch_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_post_run_stretch"/>
        <field name="sequence">10</field>
        <field name="name">Start with calves, ankles, and easy foot pressure.</field>
        <field name="duration_seconds">180</field>
    </record>
    <record id="protocol_post_run_stretch_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_post_run_stretch"/>
        <field name="sequence">20</field>
        <field name="name">Move into hip flexors and hamstrings without forcing range.</field>
        <field name="duration_seconds">300</field>
    </record>
    <record id="protocol_post_run_stretch_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_post_run_stretch"/>
        <field name="sequence">30</field>
        <field name="name">Finish with low back breathing and one minute still.</field>
        <field name="duration_seconds">120</field>
    </record>

    <record id="protocol_guided_downshift_meditation" model="drift.protocol">
        <field name="name">Guided Downshift Meditation</field>
        <field name="slug">guided-downshift-meditation</field>
        <field name="sequence">28</field>
        <field name="pillar">Rest</field>
        <field name="duration_minutes">10</field>
        <field name="intensity">Still</field>
        <field name="summary">A quiet guided reset for athletes carrying training load, work stress, or late-day stimulation.</field>
        <field name="equipment">Headphones optional</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_guided_downshift_meditation_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_guided_downshift_meditation"/>
        <field name="sequence">10</field>
        <field name="name">Sit or lie down without checking metrics.</field>
        <field name="duration_seconds">120</field>
    </record>
    <record id="protocol_guided_downshift_meditation_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_guided_downshift_meditation"/>
        <field name="sequence">20</field>
        <field name="name">Follow a slow body scan from feet to jaw.</field>
        <field name="duration_seconds">360</field>
    </record>
    <record id="protocol_guided_downshift_meditation_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_guided_downshift_meditation"/>
        <field name="sequence">30</field>
        <field name="name">Close with one simple plan for tomorrow.</field>
        <field name="duration_seconds">120</field>
    </record>

    <record id="protocol_sauna_downshift" model="drift.protocol">
        <field name="name">Sauna Downshift</field>
        <field name="slug">sauna-downshift</field>
        <field name="sequence">30</field>
        <field name="pillar">Rest</field>
        <field name="duration_minutes">22</field>
        <field name="intensity">Heat</field>
        <field name="summary">One controlled heat round, cool rinse, and a quiet landing.</field>
        <field name="equipment">Sauna hat and optional botanical blend</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_sauna_downshift_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_sauna_downshift"/>
        <field name="sequence">10</field>
        <field name="name">Enter the warm room without chasing intensity.</field>
        <field name="duration_seconds">480</field>
    </record>
    <record id="protocol_sauna_downshift_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_sauna_downshift"/>
        <field name="sequence">20</field>
        <field name="name">Cool water rinse and slow nasal breathing.</field>
        <field name="duration_seconds">240</field>
    </record>
    <record id="protocol_sauna_downshift_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_sauna_downshift"/>
        <field name="sequence">30</field>
        <field name="name">Sit for five minutes before screens or metrics.</field>
        <field name="duration_seconds">300</field>
    </record>

    <record id="protocol_quiet_reset" model="drift.protocol">
        <field name="name">Quiet Reset</field>
        <field name="slug">quiet-reset</field>
        <field name="sequence">40</field>
        <field name="pillar">Rest</field>
        <field name="duration_minutes">12</field>
        <field name="intensity">Recovery</field>
        <field name="summary">A no-hero reset for days where the system needs less input.</field>
        <field name="equipment">None</field>
        <field name="audio_ready">1</field>
    </record>
    <record id="protocol_quiet_reset_step_1" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="sequence">10</field>
        <field name="name">Dim light and lower the room input.</field>
        <field name="duration_seconds">120</field>
    </record>
    <record id="protocol_quiet_reset_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="sequence">20</field>
        <field name="name">Low nasal breathing without a pace target.</field>
        <field name="duration_seconds">480</field>
    </record>
    <record id="protocol_quiet_reset_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="sequence">30</field>
        <field name="name">Write tomorrow's first action in one line.</field>
        <field name="duration_seconds">120</field>
    </record>

    <record id="program_7_day_reset" model="drift.program">
        <field name="name">7-Day Strava Rest Reset</field>
        <field name="slug">seven-day-reset</field>
        <field name="sequence">10</field>
        <field name="pillar">System</field>
        <field name="duration_days">7</field>
        <field name="summary">A one-week preview that turns activity volume into stretching, meditation, sauna, or quiet rest.</field>
    </record>
    <record id="program_hot_miles" model="drift.program">
        <field name="name">Hot Miles</field>
        <field name="slug">hot-miles</field>
        <field name="sequence">20</field>
        <field name="pillar">Run</field>
        <field name="duration_days">14</field>
        <field name="summary">Heat-aware running and rest rituals for athletes building without forcing the day.</field>
    </record>
    <record id="program_sauna_downshift" model="drift.program">
        <field name="name">Sauna Downshift</field>
        <field name="slug">sauna-downshift-program</field>
        <field name="sequence">30</field>
        <field name="pillar">Rest</field>
        <field name="duration_days">14</field>
        <field name="summary">A conservative heat, meditation, and cool-down system for closing training days.</field>
    </record>
    <record id="program_race_week_reset" model="drift.program">
        <field name="name">Race Week Reset</field>
        <field name="slug">race-week-reset</field>
        <field name="sequence">40</field>
        <field name="pillar">System</field>
        <field name="duration_days">7</field>
        <field name="summary">A simple race-week rhythm for mobility, meditation, and lower-input evenings.</field>
    </record>

    <record id="program_7_day_reset_day_1" model="drift.program.day">
        <field name="program_id" ref="program_7_day_reset"/>
        <field name="day_index">1</field>
        <field name="title">Set the baseline</field>
        <field name="protocol_id" ref="protocol_post_run_stretch"/>
        <field name="action">Check in, complete Post-Run Stretch, and log how the first recommendation feels.</field>
    </record>
    <record id="program_7_day_reset_day_2" model="drift.program.day">
        <field name="program_id" ref="program_7_day_reset"/>
        <field name="day_index">2</field>
        <field name="title">Close the easy day</field>
        <field name="protocol_id" ref="protocol_guided_downshift_meditation"/>
        <field name="action">Keep intensity low and finish with a guided meditation.</field>
    </record>
    <record id="program_7_day_reset_day_3" model="drift.program.day">
        <field name="program_id" ref="program_7_day_reset"/>
        <field name="day_index">3</field>
        <field name="title">Add run context</field>
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="action">Use Hot Miles Prep before a controlled run or manual check-in.</field>
    </record>
    <record id="program_7_day_reset_day_4" model="drift.program.day">
        <field name="program_id" ref="program_7_day_reset"/>
        <field name="day_index">4</field>
        <field name="title">Heat or quiet rest</field>
        <field name="protocol_id" ref="protocol_sauna_downshift"/>
        <field name="action">Use Sauna Downshift only if heat feels controlled; otherwise use Quiet Reset.</field>
    </record>

    <record id="program_hot_miles_day_1" model="drift.program.day">
        <field name="program_id" ref="program_hot_miles"/>
        <field name="day_index">1</field>
        <field name="title">Prep the first hot run</field>
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="action">Start with nasal-only prep and keep the first ten minutes controlled.</field>
    </record>
    <record id="program_hot_miles_day_2" model="drift.program.day">
        <field name="program_id" ref="program_hot_miles"/>
        <field name="day_index">2</field>
        <field name="title">Recover the signal</field>
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="action">Use Nasal Reset after work or after the run to bring the day down.</field>
    </record>
    <record id="program_hot_miles_day_3" model="drift.program.day">
        <field name="program_id" ref="program_hot_miles"/>
        <field name="day_index">3</field>
        <field name="title">Keep the evening clean</field>
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="action">Avoid adding another hard input; log Quiet Reset before sleep.</field>
    </record>

    <record id="program_sauna_downshift_day_1" model="drift.program.day">
        <field name="program_id" ref="program_sauna_downshift"/>
        <field name="day_index">1</field>
        <field name="title">First controlled heat</field>
        <field name="protocol_id" ref="protocol_sauna_downshift"/>
        <field name="action">Complete one conservative heat round and a slow cool-down.</field>
    </record>
    <record id="program_sauna_downshift_day_2" model="drift.program.day">
        <field name="program_id" ref="program_sauna_downshift"/>
        <field name="day_index">2</field>
        <field name="title">Non-heat downshift</field>
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="action">Use Quiet Reset so the program is not dependent on sauna access.</field>
    </record>
    <record id="program_sauna_downshift_day_3" model="drift.program.day">
        <field name="program_id" ref="program_sauna_downshift"/>
        <field name="day_index">3</field>
        <field name="title">Breathe before heat</field>
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="action">Complete Nasal Reset before the room or before the evening landing.</field>
    </record>

    <record id="program_race_week_reset_day_1" model="drift.program.day">
        <field name="program_id" ref="program_race_week_reset"/>
        <field name="day_index">1</field>
        <field name="title">Lower the noise</field>
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="action">Use Nasal Reset to keep the first race-week decision simple.</field>
    </record>
    <record id="program_race_week_reset_day_2" model="drift.program.day">
        <field name="program_id" ref="program_race_week_reset"/>
        <field name="day_index">2</field>
        <field name="title">Quiet evening</field>
        <field name="protocol_id" ref="protocol_quiet_reset"/>
        <field name="action">Protect sleep and avoid late metric review.</field>
    </record>
    <record id="program_race_week_reset_day_3" model="drift.program.day">
        <field name="program_id" ref="program_race_week_reset"/>
        <field name="day_index">3</field>
        <field name="title">Controlled primer</field>
        <field name="protocol_id" ref="protocol_hot_miles_prep"/>
        <field name="action">Use Hot Miles Prep before a short controlled shakeout.</field>
    </record>
</odoo>
