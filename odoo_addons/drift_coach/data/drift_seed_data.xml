        <field name="duration_seconds">60</field>
    </record>
    <record id="protocol_nasal_reset_step_2" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="sequence">20</field>
        <field name="name">Inhale through the nose for four.</field>
        <field name="duration_seconds">180</field>
    </record>
    <record id="protocol_nasal_reset_step_3" model="drift.protocol.step">
        <field name="protocol_id" ref="protocol_nasal_reset"/>
        <field name="sequence">30</field>
        <field name="name">Exhale through the nose for six.</field>
        <field name="duration_seconds">120</field>
    </record>

