<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="drift_profile_portal_own_rule" model="ir.rule">
        <field name="name">DRIFT profile: portal own records</field>
        <field name="model_id" ref="model_drift_profile"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

