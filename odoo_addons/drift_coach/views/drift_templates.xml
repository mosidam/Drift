                }
                .drift-sku__grid {
                    display: grid;
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                    gap: 12px;
                    margin-top: 28px;
                }
                .drift-sku__card {
                    min-height: 190px;
                    padding: 18px;
                    border: 1px solid rgba(17, 17, 15, .12);
                    border-radius: 8px;
                    background: rgba(255, 255, 255, .34);
                }
                .drift-sku__card span {
                    color: #426760;
                    font-size: 12px;
                    font-weight: 950;
                    letter-spacing: .1em;
                    text-transform: uppercase;
                }
                .drift-sku__card h3 {
                    margin: 34px 0 8px;
                    color: #11110f;
                    font-size: 24px;
                    font-weight: 950;
                    line-height: 1;
                }
                .drift-sku__card p {
                    margin: 0;
                    color: #4d4a42;
                    line-height: 1.5;
                }
                .drift-sku__split {
                    display: grid;
                    grid-template-columns: minmax(0, .75fr) minmax(300px, .55fr);
                    gap: clamp(24px, 5vw, 72px);
                    align-items: center;
                    background: #0e1110;
                }
                .drift-sku__split p {
                    max-width: 640px;
                    color: #d9d2c1;
                    font-size: 17px;
                    line-height: 1.6;
                }
                .drift-sku__ritual {
                    display: grid;
                    gap: 10px;
                    padding: 18px;
                    border: 1px solid rgba(245, 240, 230, .16);
                    border-radius: 8px;
                    background: rgba(245, 240, 230, .06);
                }
                .drift-sku__ritual div {
                    display: grid;
                    grid-template-columns: 42px minmax(0, 1fr);
                    gap: 12px;
                    align-items: start;
                    padding-bottom: 10px;
                    border-bottom: 1px solid rgba(245, 240, 230, .12);
                }
                .drift-sku__ritual div:last-child {
                    padding-bottom: 0;
                    border-bottom: 0;
                }
                .drift-sku__ritual span {
                    color: #b8d5d0;
                    font-size: 12px;
                    font-weight: 950;
                    letter-spacing: .1em;
                }
                .drift-sku__ritual strong {
                    display: block;
                    color: #f5f0e6;
                    font-size: 18px;
                    line-height: 1.1;
                }
                .drift-sku__ritual p {
                    margin: 5px 0 0;
                    font-size: 14px;
                }
                .drift-sku__note {
                    display: grid;
                    grid-template-columns: minmax(0, 1fr) auto;
                    gap: 20px;
                    align-items: center;
                    color: #11110f;
                    background: #b8d5d0;
                }
                .drift-sku__note h2 {
                    margin: 0;
                    font-size: clamp(28px, 4vw, 52px);
                    font-weight: 950;
                    letter-spacing: 0;
                    line-height: 1;
                }
                .drift-sku__note p {
                    max-width: 760px;
                    margin: 10px 0 0;
                    color: #263b37;
                    line-height: 1.55;
                }
                .drift-sku__field-list {
                    display: grid;
                    grid-template-columns: minmax(0, .82fr) minmax(320px, .58fr);
                    gap: clamp(22px, 5vw, 70px);
                    align-items: center;
                    padding: clamp(36px, 6vw, 82px) clamp(18px, 5vw, 68px);
                    color: #11110f;
                    background: #f5f0e6;
                }
                .drift-sku__field-list h2 {
                    margin: 0;
                    max-width: 820px;
                    font-size: clamp(34px, 5vw, 66px);
                    font-weight: 950;
                    letter-spacing: 0;
                    line-height: .96;
                }
                .drift-sku__field-list p {
                    max-width: 650px;
                    margin: 14px 0 0;
                    color: #4d4a42;
                    font-size: 17px;
                    line-height: 1.55;
                }
                .drift-sku__lead-form {
                    display: grid;
                    gap: 10px;
                    padding: 18px;
                    border: 1px solid rgba(17, 17, 15, .14);
                    border-radius: 8px;
                    background: rgba(255, 255, 255, .42);
                }
                .drift-sku__lead-form label {
                    display: grid;
                    gap: 7px;
                    color: #4d4a42;
                    font-size: 12px;
                    font-weight: 950;
                    letter-spacing: .08em;
                    text-transform: uppercase;
                }
                .drift-sku__lead-form input,
                .drift-sku__lead-form select {
                    min-height: 48px;
                    width: 100%;
                    padding: 0 12px;
                    border: 1px solid rgba(17, 17, 15, .18);
                    border-radius: 8px;
                    color: #11110f;
                    background: #fffaf0;
                    font: 700 15px/1.2 Inter, system-ui, sans-serif;
                }
                .drift-sku__lead-form button {
                    min-height: 48px;
                    width: 100%;
                    border: 1px solid #11110f;
                    border-radius: 999px;
                    color: #f5f0e6;
                    background: #11110f;
                    font-size: 13px;
                    font-weight: 950;
                    letter-spacing: .08em;
                    text-transform: uppercase;
                }
                .drift-sku__form-note {
                    margin: 0 !important;
                    color: #6b675e !important;
                    font-size: 13px !important;
                }
                .drift-sku__joined {
                    margin: 0 0 10px !important;
                    padding: 10px 12px;
                    border: 1px solid rgba(66, 103, 96, .3);
                    border-radius: 8px;
                    color: #263b37 !important;
                    background: rgba(184, 213, 208, .48);
                    font-size: 14px !important;
                    font-weight: 800;
                }
                .drift-sku__trap {
                    position: absolute;
                    left: -10000px;
                    width: 1px;
                    height: 1px;
                    overflow: hidden;
                }
                .drift-sku__safety {
                    margin: 0;
                    padding: 16px clamp(18px, 5vw, 68px) 34px;
                    color: #a8a095;
                    background: #050505;
                    font-size: 13px;
                    line-height: 1.55;
