                    margin: 0 0 14px;
                    color: #b8d5d0;
                    font-size: 12px;
                    font-weight: 900;
                    letter-spacing: .15em;
                    text-transform: uppercase;
                }
                .drift-sku h1 {
                    margin: 0;
                    max-width: 900px;
                    color: #f5f0e6;
                    font-size: clamp(52px, 9vw, 124px);
                    font-weight: 950;
                    letter-spacing: 0;
                    line-height: .88;
                }
                .drift-sku__lead {
                    max-width: 650px;
                    margin: 22px 0 0;
                    color: #d9d2c1;
                    font-size: clamp(17px, 1.8vw, 22px);
                    line-height: 1.55;
                }
                .drift-sku__actions {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 10px;
