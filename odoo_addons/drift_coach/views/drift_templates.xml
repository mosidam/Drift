                .drift-sku__note {
                    padding: clamp(36px, 6vw, 82px) clamp(18px, 5vw, 68px);
                }
                .drift-sku__band {
                    background: #f5f0e6;
                    color: #11110f;
                }
                .drift-sku__band h2,
                .drift-sku__split h2 {
                    margin: 0;
                    max-width: 880px;
                    font-size: clamp(34px, 5vw, 70px);
                    font-weight: 950;
