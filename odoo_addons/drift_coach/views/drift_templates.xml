                .drift-sku__panel p {
                    margin: 8px 0 0;
                    color: #d9d2c1;
                    line-height: 1.55;
                }
                .drift-sku__panel strong {
                    color: #f5f0e6;
                    font-size: 20px;
                    font-weight: 950;
                }
                .drift-sku__band,
