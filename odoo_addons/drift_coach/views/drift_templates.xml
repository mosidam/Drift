                }
                .drift-sku a {
                    color: inherit;
                }
                .drift-sku__hero {
                    min-height: min(780px, calc(100vh - 34px));
                    display: grid;
                    grid-template-columns: minmax(0, .86fr) minmax(360px, .74fr);
                    gap: clamp(22px, 4vw, 58px);
                    align-items: stretch;
                    padding: clamp(26px, 5vw, 68px);
                    background:
                        linear-gradient(90deg, rgba(5, 5, 5, .94), rgba(5, 5, 5, .68) 48%, rgba(5, 5, 5, .26)),
                        url("/drift_coach/static/pwa/assets/drift-sauna-kit.png") center / cover no-repeat;
                }
                .drift-sku__copy {
