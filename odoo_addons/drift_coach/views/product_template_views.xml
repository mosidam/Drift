<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_drift" model="ir.ui.view">
        <field name="name">product.template.form.drift</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="drift_app" string="DRIFT App">
                    <group>
                        <field name="drift_pillar"/>
                        <field name="drift_system"/>
                        <field name="drift_app_cta"/>
                        <field name="drift_protocol_ids" widget="many2many_tags"/>
                        <field name="drift_program_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
