<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="drift_protocol_tree" model="ir.ui.view">
        <field name="name">drift.protocol.tree</field>
        <field name="model">drift.protocol</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="pillar"/>
                <field name="duration_minutes"/>
                <field name="intensity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="drift_protocol_form" model="ir.ui.view">
        <field name="name">drift.protocol.form</field>
        <field name="model">drift.protocol</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="slug"/>
                        <field name="pillar"/>
                        <field name="duration_minutes"/>
                        <field name="intensity"/>
                        <field name="equipment"/>
                        <field name="audio_ready"/>
                        <field name="audio_url"/>
                        <field name="product_template_id"/>
                        <field name="summary"/>
                    </group>
                    <field name="step_ids">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="duration_seconds"/>
                            <field name="cue"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="drift_program_tree" model="ir.ui.view">
        <field name="name">drift.program.tree</field>
        <field name="model">drift.program</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="pillar"/>
                <field name="duration_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="drift_program_form" model="ir.ui.view">
        <field name="name">drift.program.form</field>
        <field name="model">drift.program</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="slug"/>
                        <field name="pillar"/>
                        <field name="duration_days"/>
                        <field name="product_template_id"/>
                        <field name="summary"/>
                    </group>
                    <field name="day_ids">
                        <list editable="bottom">
                            <field name="day_index"/>
                            <field name="title"/>
                            <field name="protocol_id"/>
                            <field name="action"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_drift_protocol" model="ir.actions.act_window">
        <field name="name">Protocols</field>
        <field name="res_model">drift.protocol</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_drift_program" model="ir.actions.act_window">
        <field name="name">Programs</field>
        <field name="res_model">drift.program</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="drift_field_lead_tree" model="ir.ui.view">
        <field name="name">drift.field.lead.tree</field>
        <field name="model">drift.field.lead</field>
        <field name="arch" type="xml">
            <list>
                <field name="last_signup_at"/>
                <field name="email"/>
                <field name="interest"/>
                <field name="source"/>
                <field name="status"/>
                <field name="signup_count"/>
            </list>
        </field>
    </record>

    <record id="drift_field_lead_form" model="ir.ui.view">
        <field name="name">drift.field.lead.form</field>
        <field name="model">drift.field.lead</field>
        <field name="arch" type="xml">
            <form string="DRIFT Field List Lead">
                <sheet>
                    <group>
                        <field name="email"/>
                        <field name="interest"/>
                        <field name="status"/>
                    </group>
                    <group>
                        <field name="source"/>
                        <field name="signup_count" readonly="1"/>
                        <field name="last_signup_at" readonly="1"/>
                        <field name="consent_text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_drift_field_lead" model="ir.actions.act_window">
        <field name="name">Field List</field>
        <field name="res_model">drift.field.lead</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="drift_settings_form" model="ir.ui.view">
        <field name="name">drift.settings.form</field>
        <field name="model">drift.settings</field>
        <field name="arch" type="xml">
            <form string="DRIFT Settings">
                <sheet>
                    <group string="OpenAI">
                        <field name="openai_key_status" readonly="1"/>
                        <field name="openai_model"/>
                        <field name="openai_api_key" password="True" placeholder="Paste new key to replace current key"/>
                    </group>
                    <group string="Strava">
                        <field name="strava_status" readonly="1"/>
                        <field name="strava_client_id"/>
                        <field name="strava_client_secret" password="True" placeholder="Paste new secret to replace current secret"/>
                        <field name="strava_redirect_uri" placeholder="https://your-domain.com/drift/strava/callback"/>
                    </group>
                    <group string="Mobile Install">
                        <field name="ios_app_store_url" placeholder="https://apps.apple.com/app/..."/>
                        <field name="android_play_store_url" placeholder="https://play.google.com/store/apps/details?id=run.drift.coach"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save" type="object" string="Save Settings" class="btn-primary"/>
                    <button special="cancel" string="Discard" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_drift_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">drift.settings</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_drift_root" name="DRIFT" sequence="45"/>
    <menuitem id="menu_drift_protocols" name="Protocols" parent="menu_drift_root" action="action_drift_protocol" sequence="10"/>
    <menuitem id="menu_drift_programs" name="Programs" parent="menu_drift_root" action="action_drift_program" sequence="20"/>
    <menuitem id="menu_drift_field_list" name="Field List" parent="menu_drift_root" action="action_drift_field_lead" sequence="30"/>
    <menuitem id="menu_drift_settings" name="Settings" parent="menu_drift_root" action="action_drift_settings" sequence="90" groups="base.group_system"/>
</odoo>
